# 🔧 CONFIGURATION LOCALE (.env)

# Cette fichier contient les configurations pour le développement local
# Ne pas committer dans Git (ajouter à .gitignore)
# Copier et renommer en .env pour développement local

## ============================================
## BASE DE DONNÉES
## ============================================

# URL MySQL (local development)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/safar_morocco?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true

# Utilisateur MySQL
SPRING_DATASOURCE_USERNAME=root

# Mot de passe MySQL (par défaut vide pour XAMPP/local)
SPRING_DATASOURCE_PASSWORD=

# Driver MySQL
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

## ============================================
## JPA/HIBERNATE
## ============================================

# Dialect de la base de données
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQL8Dialect

# DDL Auto: create-drop | update | validate | none
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Afficher SQL dans les logs
SPRING_JPA_SHOW_SQL=false

# Format SQL
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

## ============================================
## JWT (JSON Web Token)
## ============================================

# Secret JWT (minimum 32 caractères pour HS256)
# IMPORTANT: Générer une clé sécurisée:
# Linux/Mac: openssl rand -base64 32
# Windows: https://www.random.org/cgi-bin/randbytes?nbytes=32&format=h
JWT_SECRET=YmFzZTY0LWVuY29kZWQtMzItY2hhcmFjdGVyLXNlY3JldC1rZXktZm9yLWpzb24td2ViLXRva2VuLWxvY2FsLWRldmVsb3BtZW50LW9ubHktc2VjdXJlLWluLXByb2Q=

# Durée du token d'accès (en millisecondes)
# 86400000 = 24 heures
JWT_EXPIRATION=86400000

# Durée du refresh token (en millisecondes)
# 604800000 = 7 jours
JWT_REFRESH_EXPIRATION=604800000

## ============================================
## OAUTH2 - GOOGLE
## ============================================

# Obtenir les credentials sur: https://console.cloud.google.com/
# Projet: Safar Morocco Tourism Platform

# Client ID Google
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Client Secret Google
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# URI de redirection (doit correspondre à Google Cloud Console)
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_REDIRECT_URI=http://localhost:9004/login/oauth2/code/google

# Scope (permissions demandées)
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_SCOPE=profile,email

# Endpoint d'autorisation
SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_GOOGLE_AUTHORIZATION_URI=https://accounts.google.com/o/oauth2/v2/auth

# Endpoint de token
SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_GOOGLE_TOKEN_URI=https://www.googleapis.com/oauth2/v4/token

# Endpoint d'information utilisateur
SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_GOOGLE_USER_INFO_URI=https://www.googleapis.com/oauth2/v1/userinfo

## ============================================
## SERVEUR
## ============================================

# Port du serveur
SERVER_PORT=9004

# Chemin de contexte
SERVER_SERVLET_CONTEXT_PATH=/

# Charset par défaut
SERVER_SERVLET_ENCODING_CHARSET=UTF-8

# Timeout des connexions
SERVER_TOMCAT_CONNECTION_TIMEOUT=20000

## ============================================
## LOGGING
## ============================================

# Niveau de log racine
LOGGING_LEVEL_ROOT=INFO

# Logs pour notre application
LOGGING_LEVEL_MA_SAFAR_MOROCCO=DEBUG

# Logs Spring Security (pour debug auth)
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=DEBUG

# Logs JPA/Hibernate
LOGGING_LEVEL_ORG_HIBERNATE_SQL=DEBUG
LOGGING_LEVEL_ORG_HIBERNATE_TYPE_DESCRIPTOR_SQL_BASICBINDER=TRACE

# Dossier des logs
LOGGING_FILE_NAME=logs/application.log

## ============================================
## ASYNC / THREADING
## ============================================

# Core threads pour les tâches async
SPRING_TASK_EXECUTION_POOL_CORE_SIZE=2

# Max threads pour les tâches async
SPRING_TASK_EXECUTION_POOL_MAX_SIZE=5

# Queue capacity
SPRING_TASK_EXECUTION_POOL_QUEUE_CAPACITY=100

# Prefix du nom des threads
SPRING_TASK_EXECUTION_THREAD_NAME_PREFIX=async-

# Await termination
SPRING_TASK_EXECUTION_SHUTDOWN_AWAIT_TERMINATION=true
SPRING_TASK_EXECUTION_SHUTDOWN_AWAIT_TERMINATION_PERIOD=60

## ============================================
## CORS - CONFIGURATION FRONTEND
## ============================================

# Origins autorisés (séparé par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000,http://127.0.0.1:4200

# Credentials autorisés
CORS_ALLOW_CREDENTIALS=true

# Max age (en secondes)
CORS_MAX_AGE=3600

# Methods autorisés
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH

# Headers autorisés
CORS_ALLOWED_HEADERS=*

## ============================================
## APPLICATION PROPERTIES
## ============================================

# Application name
SPRING_APPLICATION_NAME=Safar-Morocco-Backend

# Version application
APP_VERSION=1.0

# Description
APP_DESCRIPTION=Backend pour la plateforme de tourisme Safar Morocco

# Environnement
APP_ENVIRONMENT=development

## ============================================
## CACHE
## ============================================

# Type de cache
SPRING_CACHE_TYPE=simple

# TTL du cache (en millisecondes)
SPRING_CACHE_SIMPLE_TTL=600000

## ============================================
## ACTUATOR (Health & Metrics)
## ============================================

# Endpoints à exposer
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics

# Base path
MANAGEMENT_ENDPOINTS_WEB_BASE_PATH=/actuator

# Health détails
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

## ============================================
## MAIL (optionnel - pour futures notifications)
## ============================================

# SMTP Host
SPRING_MAIL_HOST=smtp.gmail.com

# SMTP Port
SPRING_MAIL_PORT=587

# Email de l'application
SPRING_MAIL_USERNAME=your-email@gmail.com

# Mot de passe email (ou app password)
SPRING_MAIL_PASSWORD=your-app-password

# TLS
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true

# Sender
SPRING_MAIL_PROPERTIES_MAIL_SMTP_FROM=noreply@safar-morocco.com

## ============================================
## ANNOTATIONS UTILES
## ============================================

# Notes importantes pour développeurs:
# 1. JWT_SECRET: Générer une nouvelle clé pour production
# 2. GOOGLE OAuth2: Créer une app Google Cloud Console
# 3. CORS: Adapter les origins selon votre environnement
# 4. BD: S'assurer que MySQL est running
# 5. Logging: Augmenter le niveau en cas de debug
# 6. HTTPS: À mettre en place pour production
# 7. Ne jamais committer ce fichier avec les vraies credentials!

## ============================================
## COMMANDES UTILES
## ============================================

# Générer une clé JWT sécurisée (Linux/Mac):
# openssl rand -base64 32

# Générer une clé JWT sécurisée (Windows PowerShell):
# [System.Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((New-Guid).ToString() + (New-Guid).ToString()))

# Démarrer XAMPP (Windows):
# xampp-control.exe

# Démarrer MySQL (Linux):
# sudo service mysql start

# Tester la connexion MySQL:
# mysql -u root -h localhost -p

# Vérifier l'application est running:
# curl http://localhost:9004/actuator/health
